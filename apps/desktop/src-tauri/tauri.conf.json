{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "protoAgent",
  "version": "0.1.0",
  "identifier": "studio.protolabs.protoagent",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://127.0.0.1:5173/app/",
    "beforeDevCommand": "npm --workspace @protoagent/web run dev",
    "beforeBuildCommand": "npm --workspace @protoagent/web run build -- --base ./"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/protoagent-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
