# Build hygiene — what NOT to ship into /opt/protoagent.
#
# The Dockerfile does a single `COPY . /opt/protoagent/` so adding a new
# top-level source file doesn't require a Dockerfile update. Everything
# listed here is excluded from that copy.

# Git / CI
.git/
.gitignore
.github/

# Dev assistant / editor state
.claude/
.automaker/
.infisical.json
.vscode/
.idea/

# Tooling that doesn't belong at runtime
Dockerfile
.dockerignore
README.md
*.md

# Python build artefacts
**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/
.venv/
venv/
.env
.env.*
config/secrets.yaml
# Live config is generated from the .example template at runtime in the
# config volume — never bake a developer's local copy into the image.
config/langgraph-config.yaml

# Tests — not needed at runtime; image stays lean
tests/

# Docs site — VitePress builds to gh-pages, not into the container
docs/
node_modules/
package.json
package-lock.json

# Seccomp profile — Docker reads this on the host at runtime
# (via docker-compose security_opt), NOT from inside the image
seccomp-profile.json

# OS junk
.DS_Store
Thumbs.db
