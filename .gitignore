__pycache__/
*.pyc
*.pyo
.env
.venv/
.venv-*/
venv/

# Secrets overlay — the wizard/drawer write the model API key + A2A bearer
# here instead of the tracked config YAML. Never commit it.
config/secrets.yaml

# Live runtime config — generated from langgraph-config.example.yaml on first
# run and rewritten by the wizard/drawer. The tracked file is the .example
# template; the live copy is per-deployment state, so it stays out of git.
config/langgraph-config.yaml

# Setup-wizard completion marker — per-deployment runtime state, written once
# the wizard has been run. Not config to commit.
config/.setup-complete

# Local-run artifacts — autostart stdout/stderr logs + memory middleware
# fallback directory when /sandbox is not available.
logs/
.proto/
*.egg-info/
dist/
build/
.DS_Store
*.db
*.jsonl
# Workspace-config standard: the beads issue export is the committed source of truth
!.beads/issues.jsonl

# protoLabs Studio agent workspace (never commit)
.automaker-lock
.claude/
.worktrees/
worktrees/

# VitePress build artifacts + node modules
node_modules/
docs/.vitepress/dist/
docs/.vitepress/cache/

# protoLabs workspace-config standard
.beads/beads.db
.beads/beads.db-*
.beads/.br_history/
.automaker/features/
.automaker/checkpoints/
.automaker/trajectory/
.automaker/projects/
.automaker/notes/
.automaker/knowledge.db
.automaker/knowledge.db-*
.beads/last-touched

# Built Tauri sidecar binaries (produced by apps/desktop/sidecar/build_sidecar.py)
apps/desktop/src-tauri/binaries/
# PyInstaller sidecar build workdir
/build/sidecar/

# Playwright E2E artifacts (apps/web smoke harness)
apps/web/test-results/
apps/web/playwright-report/
apps/web/blob-report/
apps/web/.playwright/
